@model Restaurante.ViewModels.LoginViewModel

<style>
    .login-container {
        max-width: 450px;
        margin: 80px auto;
        background: linear-gradient(145deg, #132f44, #0f2233);
        padding: 40px;
        border-radius: 25px;
        border: 1px solid rgba(212,175,55,0.3);
        box-shadow:
            0 0 30px rgba(212,175,55,0.15),
            inset 0 0 20px rgba(255,255,255,0.02);
        backdrop-filter: blur(6px);
    }

    .login-title {
        text-align: center;
        color: #f1d27a;
        font-size: 1.8rem;
        margin-bottom: 30px;
        letter-spacing: 2px;
        text-shadow: 0 0 10px rgba(212,175,55,0.3);
    }

    .form-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        margin-bottom: 6px;
        color: #d4af37;
        font-size: 0.9rem;
    }

    .form-group input {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid rgba(212,175,55,0.2);
        background-color: #081520;
        color: #f5f5f5;
        transition: 0.3s;
    }

    .form-group input:focus {
        border-color: #d4af37;
        box-shadow: 0 0 10px rgba(212,175,55,0.3);
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #d4af37, #f1d27a);
        border: none;
        border-radius: 15px;
        color: #081520;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 10px;
        box-shadow: 0 0 15px rgba(212,175,55,0.3);
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(212,175,55,0.5);
    }

    .link-register {
        text-align: center;
        margin-top: 15px;
        font-size: 0.9rem;
    }

    .link-register a {
        color: #f1d27a;
        text-decoration: none;
    }

    .link-register a:hover {
        text-decoration: underline;
    }

</style>

<div class="login-container">

    <div class="login-title">ENTRAR</div>

    <form asp-action="Login" method="post">

        <div asp-validation-summary="All"></div>

        <div class="form-group">
            <label>Usuário</label>
            <input asp-for="UserName" />
        </div>

        <div class="form-group">
            <label>Senha</label>
            <input asp-for="Password" type="password" />
        </div>

        <div class="form-group">
            <label>
                <input asp-for="RememberMe" type="checkbox" />
                Lembrar de mim
            </label>
        </div>

        <button type="submit" class="btn-login">Entrar</button>

        <div class="link-register">
            Não tem conta?
            <a asp-action="Register">Criar conta</a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}