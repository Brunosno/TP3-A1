@model Restaurante.ViewModels.RegisterViewModel

<style>
    .register-container {
        max-width: 450px;
        margin: 80px auto;
        background: linear-gradient(145deg, #132f44, #0f2233);
        padding: 40px;
        border-radius: 25px;
        border: 1px solid rgba(212,175,55,0.3);
        box-shadow: 
            0 0 30px rgba(212,175,55,0.15),
            inset 0 0 20px rgba(255,255,255,0.02);
        backdrop-filter: blur(6px);
    }

    .register-title {
        text-align: center;
        color: #f1d27a;
        font-size: 1.8rem;
        margin-bottom: 30px;
        letter-spacing: 2px;
        text-shadow: 0 0 10px rgba(212,175,55,0.3);
    }

    .form-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        margin-bottom: 6px;
        color: #d4af37;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .form-group input {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid rgba(212,175,55,0.2);
        background-color: #081520;
        color: #f5f5f5;
        outline: none;
        transition: 0.3s;
    }

    .form-group input:focus {
        border-color: #d4af37;
        box-shadow: 0 0 10px rgba(212,175,55,0.3);
    }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #d4af37, #f1d27a);
        border: none;
        border-radius: 15px;
        color: #081520;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 10px;
        box-shadow: 0 0 15px rgba(212,175,55,0.3);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(212,175,55,0.5);
    }

    .validation-summary-errors {
        background: rgba(255, 0, 0, 0.1);
        border: 1px solid rgba(255, 0, 0, 0.3);
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
        color: #ffb3b3;
    }
</style>

<div class="register-container">

    <div class="register-title">CRIAR CONTA</div>

    <form asp-action="Register" method="post">

        <div asp-validation-summary="All"></div>

        <div class="form-group">
            <label>Nome</label>
            <input asp-for="Name" />
        </div>

        <div class="form-group">
            <label>Username</label>
            <input asp-for="UserName" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" />
        </div>

        <div class="form-group">
            <label>Senha</label>
            <input asp-for="Password" type="password" />
        </div>

        <button type="submit" class="btn-submit">Cadastrar</button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}