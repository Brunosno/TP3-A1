@using Microsoft.AspNetCore.Identity
@using Restaurante.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var user = User.Identity.IsAuthenticated
        ? await UserManager.GetUserAsync(User)
        : null;
}

<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Restaurante</title>

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

        <style>
            body {
                background: radial-gradient(circle at top, #0f2233, #081520);
                color: #f5f5f5;
                font-family: 'Segoe UI', sans-serif;
            }

            /* NAVBAR */
            .navbar-custom {
                background: linear-gradient(145deg, #132f44, #0f2233);
                border-bottom: 1px solid rgba(212,175,55,0.2);
                padding: 15px 30px;
            }

            .navbar-brand {
                color: #f1d27a !important;
                font-weight: bold;
                letter-spacing: 2px;
            }

            .nav-link {
                color: #f5f5f5 !important;
                margin-right: 15px;
                transition: 0.3s;
            }

            .nav-link:hover {
                color: #d4af37 !important;
                text-shadow: 0 0 8px rgba(212,175,55,0.4);
            }

            /* USER AREA */
            .user-box {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .user-img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid #d4af37;
            }

            .btn-logout {
                background: transparent;
                border: 1px solid rgba(212,175,55,0.4);
                color: #f1d27a;
                padding: 6px 12px;
                border-radius: 10px;
                transition: 0.3s;
            }

            .btn-logout:hover {
                background: rgba(212,175,55,0.2);
            }

            /* CONTAINER */
            .main-container {
                width: 92%;
                margin: 40px auto;
            }

            /* FOOTER */
            footer {
                text-align: center;
                padding: 20px;
                color: #aaa;
                border-top: 1px solid rgba(212,175,55,0.2);
                margin-top: 40px;
            }
        </style>
    </head>

    <body>

        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    RESTAURANTE
                </a>

                <div class="collapse navbar-collapse justify-content-between">

                    <!-- MENU -->
                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.IsInRole("ADMIN"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dish" asp-action="Create">
                                    Novo Prato
                                </a>
                            </li>
                        }

                    </ul>

                    <div>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="user-box">

                                <img src="@(user?.ImageUrl ?? "/images/default-user.png")"
                                    class="user-img" />

                                <span>@user?.UserName</span>

                                <a asp-controller="Profile" asp-action="Index"
                                class="nav-link">Perfil</a>

                                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                    <button type="submit" class="btn-logout">Sair</button>
                                </form>

                            </div>
                        }
                        else
                        {
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                Login
                            </a>

                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                Cadastro
                            </a>
                        }
                    </div>

                </div>
            </div>
        </nav>

        <!-- CONTEÚDO -->
        <div class="main-container">
            @RenderBody()
        </div>

        <!-- FOOTER -->
        <footer>
            © 2026 - Restaurante
        </footer>

        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)

    </body>
</html>